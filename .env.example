# TRUF Network Configuration (testnet)
TRUF_NODE_URL=https://gateway.testnet.truf.network

# Private key for signing transactions (64 hex characters, no 0x prefix)
# Generate a new key with: python -m lp_bot.main --generate-key
TRUF_API_TOKEN=your_testnet_private_key_here

# LP Bot Configuration
LP_BOT_ALPHA=0.30
LP_BOT_PRICING_METHOD=equal
LP_BOT_ORDER_AMOUNT=100

# Volume-weighted pricing options (only used with --method volume)
LP_BOT_TIME_DECAY=false
LP_BOT_HALF_LIFE=60.0
LP_BOT_TARGET_DEPTH=0.30
